{
  "name": "@framepayments/cli",
  "version": "0.0.0",
  "description": "Frame CLI — sandbox developer tooling for the Frame API",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "vitest run",
    "build": "esbuild src/cli.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/cli.js --external:keytar --banner:js=\"import{createRequire}from'node:module';const require=createRequire(import.meta.url);\"",
    "dev": "tsx src/cli.ts",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier --write src",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Frame-Payments/frame-cli.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Frame-Payments/frame-cli/issues"
  },
  "homepage": "https://github.com/Frame-Payments/frame-cli#readme",
  "type": "module",
  "bin": {
    "frame": "./bin/frame"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@rails/actioncable": "^8.1.300",
    "commander": "^14.0.3",
    "keytar": "^7.9.0",
    "ws": "^8.20.0",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
